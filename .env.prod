ENV=prod
NODE_ENV=production
PORT=5000

DB_HOST=<render-postgres-host>
DB_PORT=5432
DB_USER=<render-user>
DB_PASS=<render-password>
DB_NAME=<render-db-name>

CORS_ORIGIN=https://yourfrontend.com

JWT_SECRET=prod_secret_key
JWT_REFRESH_SECRET=prod_refresh_secret
ACCESS_TTL=15m
REFRESH_TTL=7d
JWT_ISSUER=https://yourbackend.com
API_BASE_URL=
ENABLE_CRON=true